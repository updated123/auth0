# Auth0 / Okta CIC — Application credentials (Regular Web App)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-app-client-id
AUTH0_CLIENT_SECRET=your-app-client-secret

# API Audience — must match the Auth0 API identifier you create
AUTH0_AUDIENCE=platform-api

# Auth0 Management API credentials (Machine-to-Machine app)
AUTH0_MGMT_CLIENT_ID=your-mgmt-client-id
AUTH0_MGMT_CLIENT_SECRET=your-mgmt-client-secret

# Platform application
APP_BASE_URL=http://localhost:8000

# Session signing — must be >= 32 random chars in production
SECRET_KEY=change-me-32-chars-minimum-REPLACE

# Shared secret used to verify Auth0 Action webhook payloads (HMAC-SHA256)
WEBHOOK_SECRET=change-me-webhook-secret-REPLACE

# SQLite for local POC; swap for postgresql://... in production
DATABASE_URL=sqlite:///./poc.db
